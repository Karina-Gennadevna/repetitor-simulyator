{
  "functions": {
    "api/generate.js": { "maxDuration": 30 },
    "api/check.js":    { "maxDuration": 30 },
    "api/tts.js":      { "maxDuration": 20 }
  },
  "rewrites": [
    { "source": "/", "destination": "/app/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
